{
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/admin/?",
            "dest": "/api/proxy.php?file=admin/index.php"
        },
        {
            "src": "/(admin/.*\\.php)",
            "dest": "/api/proxy.php?file=$1"
        },
        {
            "src": "/(.*\\.php)",
            "dest": "/api/proxy.php?file=$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/proxy.php?file=index.php"
        }
    ]
}
