# Variables d'environnement pour Vercel
# Copiez ces variables dans les settings de votre projet Vercel

# Type de base de données
DB_TYPE=supabase

# Configuration Supabase
# Utilisez la clé publique/anonyme (anon/public key) pour SUPABASE_KEY
# et la clé service-role si vous avez besoin d'accès admin via SUPABASE_AUTH_TOKEN
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-publishable-key-here
SUPABASE_AUTH_TOKEN=your-service-role-key-here

# Configuration MySQL (optionnel, pour rollback)
DB_HOST=127.0.0.1
DB_NAME=portfolio
DB_USER=root
DB_PASS=
